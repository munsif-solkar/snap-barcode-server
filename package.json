{
  "name": "snap-barcode-server",
  "version": "1.0.0",
  "description": "Barcode scanner using mobile camera",
  "homepage": "https://github.com/munsif-solkar/snap-barcode-server#readme",
  "bugs": {
    "url": "https://github.com/munsif-solkar/snap-barcode-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/munsif-solkar/snap-barcode-server.git"
  },
  "license": "ISC",
  "author": "Munsif Solkar",
  "type": "commonjs",
  "main": "main/main.js",
  "scripts": {
    "start": "electron main/main.js --no-sandbox",
    "build-css": "npx tailwindcss -i ./ui/styles/input.css -o ./ui/styles/tw-style.css --minify",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dist":"electron-builder"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    
    "tailwindcss": "^4.2.1",
    "ws": "^8.19.0",
    "@nut-tree-fork/nut-js": "^4.2.6"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "electron": "^40.8.0"
  },
  "build": {
  "appId": "com.snapbarcodeserver.app",
  "compression":"maximum",
  "asarUnpack": [
    "**/libffmpeg*",
    "**/chrome-sandbox"
  ],
  "productName": "Snap Barcode Server",
  "win": {
    "target": "nsis",
    "icon":"assets/snap-barcode-logo.ico"
  },
  "linux":{
    "target":"AppImage",
    "category":"Utility",
    "executableName": "snap-barcode-server",
    "icon":"assets/snap-barcode-logo.png"
  }
  }
}
